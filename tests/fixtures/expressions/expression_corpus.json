        "pyspark": "((F.col(\"Status\") == F.lit(\"Active\")) | (F.col(\"Status\") == F.lit(\"Pending\")))",
        "sql": "((`Status` = 'Active') OR (`Status` = 'Pending'))"
    },
    {
        "description": "Logical NOT with IsNull",
