    {
        "description": "Complex IF with function in condition",
        "alteryx": "IF Contains([Email], \"@\") AND Length([Email]) > 5 THEN \"valid\" ELSE \"invalid\" ENDIF",
        "pyspark": "F.when(((F.col(\"Email\")).contains(F.lit(\"@\")) & (F.length(F.col(\"Email\")) > 5)), F.lit(\"valid\")).otherwise(F.lit(\"invalid\"))",
        "sql": "CASE WHEN (`Email` LIKE CONCAT('%', '@', '%') AND (LENGTH(`Email`) > 5)) THEN 'valid' ELSE 'invalid' END"
    },
