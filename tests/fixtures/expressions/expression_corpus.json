    {
        "description": "Simple IF/THEN/ELSE/ENDIF",
        "alteryx": "IF [Status] = \"Active\" THEN 1 ELSE 0 ENDIF",
        "pyspark": "F.when((F.col(\"Status\") == F.lit(\"Active\")), 1).otherwise(0)",
        "sql": "CASE WHEN (`Status` = 'Active') THEN 1 ELSE 0 END"
    },
    {
        "description": "Nested IF with ELSEIF",
        "alteryx": "IF [A] > 0 THEN \"pos\" ELSEIF [A] = 0 THEN \"zero\" ELSE \"neg\" ENDIF",
        "pyspark": "F.when((F.col(\"A\") > 0), F.lit(\"pos\")).when((F.col(\"A\") == 0), F.lit(\"zero\")).otherwise(F.lit(\"neg\"))",
        "sql": "CASE WHEN (`A` > 0) THEN 'pos' WHEN (`A` = 0) THEN 'zero' ELSE 'neg' END"
    },
    {
        "description": "Logical AND with two comparisons",
        "alteryx": "[A] > 0 AND [B] < 100",
        "pyspark": "((F.col(\"A\") > 0) & (F.col(\"B\") < 100))",
        "sql": "((`A` > 0) AND (`B` < 100))"
    },
    {
