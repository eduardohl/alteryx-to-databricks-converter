<?xml version="1.0"?>
<AlteryxDocument yxmdVer="2023.1">
  <Nodes>
    <Node ToolID="1">
      <GuiSettings Plugin="AlteryxBasePluginsGui.TextInput.TextInput">
        <Position x="50" y="150"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <NumRows value="6"/>
          <Fields>
            <Field name="CustomerID" type="Int32" size="4"/>
            <Field name="FirstName" type="V_WString" size="50"/>
            <Field name="LastName" type="V_WString" size="50"/>
            <Field name="Email" type="V_WString" size="100"/>
            <Field name="Segment" type="V_WString" size="20"/>
          </Fields>
          <Data>
            <r><c>101</c><c>Sarah</c><c>Chen</c><c>s.chen@acme.com</c><c>Enterprise</c></r>
            <r><c>102</c><c>James</c><c>Wilson</c><c>j.wilson@globex.com</c><c>SMB</c></r>
            <r><c>103</c><c>Maria</c><c>Garcia</c><c>m.garcia@initech.com</c><c>Enterprise</c></r>
            <r><c>104</c><c>David</c><c>Kim</c><c>d.kim@umbrella.com</c><c>Mid-Market</c></r>
            <r><c>105</c><c>Emily</c><c>Brown</c><c>e.brown@waystar.com</c><c>Enterprise</c></r>
            <r><c>106</c><c>Michael</c><c>Lee</c><c>m.lee@hooli.com</c><c>SMB</c></r>
          </Data>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>CRM Customers</Name>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="2">
      <GuiSettings Plugin="AlteryxBasePluginsGui.TextInput.TextInput">
        <Position x="50" y="350"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <NumRows value="8"/>
          <Fields>
            <Field name="TxnID" type="Int32" size="4"/>
            <Field name="CustID" type="Int32" size="4"/>
            <Field name="Amount" type="Double" size="8"/>
            <Field name="TxnDate" type="Date" size="10"/>
            <Field name="Product" type="V_WString" size="50"/>
          </Fields>
          <Data>
            <r><c>1001</c><c>101</c><c>15000</c><c>2024-01-15</c><c>Platform License</c></r>
            <r><c>1002</c><c>102</c><c>2500</c><c>2024-01-20</c><c>Basic Plan</c></r>
            <r><c>1003</c><c>103</c><c>45000</c><c>2024-02-01</c><c>Enterprise Suite</c></r>
            <r><c>1004</c><c>101</c><c>8000</c><c>2024-02-10</c><c>Add-on Module</c></r>
            <r><c>1005</c><c>104</c><c>12000</c><c>2024-03-01</c><c>Platform License</c></r>
            <r><c>1006</c><c>105</c><c>55000</c><c>2024-03-15</c><c>Enterprise Suite</c></r>
            <r><c>1007</c><c>102</c><c>3500</c><c>2024-03-20</c><c>Basic Plan</c></r>
            <r><c>1008</c><c>106</c><c>1800</c><c>2024-04-01</c><c>Starter Plan</c></r>
          </Data>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Transactions</Name>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="3">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Formula.Formula">
        <Position x="200" y="150"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <FormulaFields>
            <FormulaField expression="[FirstName] + ' ' + [LastName]" field="FullName" size="100" type="V_WString"/>
            <FormulaField expression="Uppercase(Left([Email], FindString([Email], '@')))" field="EmailPrefix" size="50" type="V_WString"/>
          </FormulaFields>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Create Full Name &amp; Email Prefix</Name>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="4">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Join.Join">
        <Position x="400" y="250"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <JoinByRecordPos Value="False"/>
          <JoinFields>
            <JoinField LeftField="CustomerID" RightField="CustID"/>
          </JoinFields>
          <SelectConfiguration>
            <Configuration outputConnection="Join">
              <OrderChanged Value="False"/>
              <SelectFields>
                <SelectField field="Right_CustID" selected="False"/>
                <SelectField field="*Unknown" selected="True"/>
              </SelectFields>
            </Configuration>
          </SelectConfiguration>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Join Customer + Transactions</Name>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="5">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Summarize.Summarize">
        <Position x="600" y="250"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <SummarizeFields>
            <SummarizeField field="CustomerID" action="GroupBy" rename="CustomerID"/>
            <SummarizeField field="FullName" action="First" rename="FullName"/>
            <SummarizeField field="Segment" action="First" rename="Segment"/>
            <SummarizeField field="Amount" action="Sum" rename="TotalRevenue"/>
            <SummarizeField field="Amount" action="Avg" rename="AvgDealSize"/>
            <SummarizeField field="TxnID" action="Count" rename="TotalTransactions"/>
            <SummarizeField field="TxnDate" action="Max" rename="LastPurchaseDate"/>
          </SummarizeFields>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Build Customer 360 Profile</Name>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="6">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Sort.Sort">
        <Position x="800" y="250"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <SortFields>
            <SortField field="TotalRevenue" order="Descending"/>
          </SortFields>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Rank by Revenue</Name>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="7">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileOutput.DbFileOutput">
        <Position x="1000" y="250"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <File FileFormat="19" FilePath="customer_360_profiles.csv"/>
          <WriteMode>Overwrite</WriteMode>
        </Configuration>
        <Annotation DisplayMode="0">
          <Name>Export Customer 360</Name>
        </Annotation>
      </Properties>
    </Node>
  </Nodes>
  <Connections>
    <Connection>
      <Origin ToolID="1" Connection="Output"/>
      <Destination ToolID="3" Connection="Input"/>
    </Connection>
    <Connection>
      <Origin ToolID="3" Connection="Output"/>
      <Destination ToolID="4" Connection="Left"/>
    </Connection>
    <Connection>
      <Origin ToolID="2" Connection="Output"/>
      <Destination ToolID="4" Connection="Right"/>
    </Connection>
    <Connection>
      <Origin ToolID="4" Connection="Join"/>
      <Destination ToolID="5" Connection="Input"/>
    </Connection>
    <Connection>
      <Origin ToolID="5" Connection="Output"/>
      <Destination ToolID="6" Connection="Input"/>
    </Connection>
    <Connection>
      <Origin ToolID="6" Connection="Output"/>
      <Destination ToolID="7" Connection="Input"/>
    </Connection>
  </Connections>
  <Properties>
    <Memory Default="True"/>
    <GlobalRecordLimit Value="0"/>
    <TempFiles Default="True"/>
    <Annotation on="True" includeToolName="False"/>
    <ConvErrorLimit Value="10"/>
    <ConvErrorLimit_Stop Value="False"/>
    <CancelOnError Value="False"/>
    <DisableBrowse Value="False"/>
    <EnablePerformanceProfiling Value="False"/>
    <RunWithE2 Value="True"/>
    <PredictiveToolsCodePage Value="65001"/>
    <DisableAllOutput Value="False"/>
    <ShowAllMacroMessages Value="False"/>
    <ShowConnectionErrors Value="True"/>
    <ShowConversionErrors Value="True"/>
    <ShowFieldConversionErrors Value="True"/>
    <MetaInfo>
      <Name>customer_360_etl</Name>
      <Description>Customer 360 ETL: Joins CRM data with transactions, builds revenue profiles per customer</Description>
      <Author>a2d Demo</Author>
    </MetaInfo>
  </Properties>
</AlteryxDocument>
