<?xml version="1.0"?>
<AlteryxDocument yxmdVer="2023.1">
  <Nodes>
    <Node ToolID="1">
      <GuiSettings Plugin="AlteryxBasePluginsGui.TextInput.TextInput">
        <Position x="50" y="250"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <NumRows value="12"/>
          <Fields>
            <Field name="CustomerID" type="Int32" size="4"/>
            <Field name="Tenure" type="Int32" size="4"/>
            <Field name="MonthlyCharges" type="Double" size="8"/>
            <Field name="TotalCharges" type="Double" size="8"/>
            <Field name="NumSupportCalls" type="Int32" size="4"/>
            <Field name="ContractType" type="V_WString" size="20"/>
            <Field name="PaymentMethod" type="V_WString" size="30"/>
            <Field name="Churned" type="Int32" size="4"/>
          </Fields>
          <Data>
            <r><c>3001</c><c>48</c><c>65.50</c><c>3144.00</c><c>1</c><c>TwoYear</c><c>BankTransfer</c><c>0</c></r>
