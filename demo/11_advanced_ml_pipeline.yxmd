<AlteryxDocument yxmdVer="2023.1">
  <Nodes>
    <Node ToolID="1">
      <GuiSettings Plugin="AlteryxBasePluginsGui.TextInput.TextInput">
        <Position x="50" y="250"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <NumRows value="10"/>
          <Fields>
            <Field name="ID" type="Int32" size="4"/>
            <Field name="Feature1" type="Double" size="8"/>
            <Field name="Feature2" type="Double" size="8"/>
            <Field name="Feature3" type="Double" size="8"/>
