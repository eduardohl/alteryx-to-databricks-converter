            <r><c>10</c><c>1.5</c><c>4.7</c><c>0.6</c><c>1</c></r>
          </Data>
        </Configuration>
        <Annotation DisplayMode="0"><Name>ML Training Data</Name></Annotation>
      </Properties>
    </Node>
    <Node ToolID="2">
      <GuiSettings Plugin="AlteryxPredictivePluginsGui.BoostedModel.BoostedModel">
        <Position x="300" y="100"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <TargetField>Label</TargetField>
          <FeatureFields>Feature1,Feature2,Feature3</FeatureFields>
          <ModelType>classification</ModelType>
          <NumIterations>100</NumIterations>
          <MaxDepth>5</MaxDepth>
          <LearningRate>0.1</LearningRate>
        </Configuration>
        <Annotation DisplayMode="0"><Name>Gradient Boosted Trees</Name></Annotation>
      </Properties>
    </Node>
    <Node ToolID="3">
      <GuiSettings Plugin="AlteryxPredictivePluginsGui.NaiveBayes.NaiveBayes">
        <Position x="300" y="250"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <TargetField>Label</TargetField>
          <FeatureFields>Feature1,Feature2,Feature3</FeatureFields>
          <Smoothing>1.0</Smoothing>
        </Configuration>
        <Annotation DisplayMode="0"><Name>Naive Bayes Classifier</Name></Annotation>
      </Properties>
    </Node>
    <Node ToolID="4">
      <GuiSettings Plugin="AlteryxPredictivePluginsGui.KCentroids.KCentroids">
        <Position x="300" y="400"/>
      </GuiSettings>
      <Properties>
        <Configuration>
          <FeatureFields>Feature1,Feature2,Feature3</FeatureFields>
          <K>3</K>
          <MaxIterations>50</MaxIterations>
        </Configuration>
        <Annotation DisplayMode="0"><Name>K-Means Clustering</Name></Annotation>
      </Properties>
    </Node>
    <Node ToolID="5">
      <GuiSettings Plugin="AlteryxPredictivePluginsGui.PrincipalComponents.PrincipalComponents">
        <Position x="300" y="550"/>
      </GuiSettings>
      <Properties>
        <Configuration>
